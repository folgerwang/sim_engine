#version 460
#extension GL_EXT_mesh_shader : require
#include "global_definition.glsl.h"

// ─── csm_silhouette_prepass.mesh ────────────────────────────────────────
// Per-cascade "in-frustum silhouette fill" prepass.
//
// Goal: pre-fill every shadow-map texel that the main camera's frustum
// CANNOT see with a depth value (0.0) that makes the standard LESS_OR_
// EQUAL shadow test reject every real caster.  Equivalently, fill the
// texels the camera CAN see with depth=1.0, leaving the rest at the
// render-pass clear value (0.0).
//
// This is the classical CSM "silhouette mask" optimization: shadow
// casters whose projected fragments land outside the camera's footprint
// in the shadow map contribute zero useful pixels (no main-view pixel
// will ever sample those texels).  Pre-rejecting them lets Hi-Z prune
// whole primitives at PD setup time before they reach the rasterizer —
// which is the dominant bottleneck the Nsight capture revealed for this
// pass (blue Top-Level Throughput, ~86% unallocated warps).
//
// Geometry: one workgroup per cascade emits the 12 triangles of that
// cascade's main-camera frustum slab (a hexahedron in world space).
// Vertex transform: cascade_VP * corner_ws, then we FORCE z = w so the
// final NDC z is exactly 1.0 — independent of where the actual slab
// projects on the depth axis.  That guarantees the prepass writes the
// MAX depth value the buffer supports, so any later real-caster write
// (z < 1.0) passes LESS_OR_EQUAL inside the silhouette.
//
// Depth state for this pipeline (in cluster_renderer.cpp):
//   depth test  = ALWAYS  (so the forced 1.0 always replaces clear 0.0)
//   depth write = ON
//   cull mode   = NONE    (we want both sides of the hex to cover the
//                          silhouette regardless of vertex winding)
// ─────────────────────────────────────────────────────────────────────────

layout(local_size_x = 8) in;            // 8 lanes = 8 hex corners
layout(triangles, max_vertices = 8, max_primitives = 12) out;

// World-space margin we push every slab corner outward by (relative to
// the slab's centroid) before projecting.  Has to be ≥ the maximum PCF
// kernel radius used at shadow lookup, otherwise a receiver near the
// silhouette edge will have PCF taps that land in the cleared 0-region
// just outside the silhouette and read shadow-depth = 0 → "in shadow"
// → harsh dark fringe on the silhouette boundary.
//
// Sources for the PCF radius cap:
//   base.frag             : CSM_MAX_PCF_RADIUS_WORLD = 0.80
//   cluster_bindless.frag : CSM_MAX_PCF_RADIUS_WORLD = 0.80
//   deferred_resolve.comp : CSM_MAX_PCF_RADIUS_WORLD = 0.80
//
// We add ~25% headroom for bilinear filter footprint and to absorb a
// future PCF-radius bump without having to re-tune this shader.  All
// units are world-space metres; the same value works across every
// cascade because PCF reaches the same physical distance regardless of
// which cascade is in use.
#define SILHOUETTE_MARGIN_WS 1.0

out gl_MeshPerVertexEXT {
    vec4 gl_Position;
} gl_MeshVerticesEXT[];

out perprimitiveEXT gl_MeshPerPrimitiveEXT {
    int gl_Layer;
} gl_MeshPrimitivesEXT[];

layout(std140, set = RUNTIME_LIGHTS_PARAMS_SET, binding = RUNTIME_LIGHTS_CONSTANT_INDEX)
    uniform RuntimeLightsUBO {
    RuntimeLightsParams lights_params;
};

// 12 triangles covering a hexahedron's 6 faces.  Each face is a quad
// triangulated as two tris.  Vertex indices reference the 8 corners
// in the same order computeCascadeMatrices exports them:
//   0 = near TL  1 = near TR  2 = near BL  3 = near BR
//   4 = far  TL  5 = far  TR  6 = far  BL  7 = far  BR
const uvec3 kHexTris[12] = uvec3[12](
    // Near face (z = -near in view space, towards camera in world space).
    uvec3(0u, 1u, 3u), uvec3(0u, 3u, 2u),
    // Far face.
    uvec3(4u, 6u, 7u), uvec3(4u, 7u, 5u),
    // Left face.
    uvec3(0u, 2u, 6u), uvec3(0u, 6u, 4u),
    // Right face.
    uvec3(1u, 5u, 7u), uvec3(1u, 7u, 3u),
    // Top face.
    uvec3(0u, 4u, 5u), uvec3(0u, 5u, 1u),
    // Bottom face.
    uvec3(2u, 3u, 7u), uvec3(2u, 7u, 6u)
);

shared vec3 s_centroid_ws;

void main() {
    uint cascade_idx = gl_WorkGroupID.x;
    uint lane        = gl_LocalInvocationID.x;
    mat4 vp          = lights_params.light_view_proj[cascade_idx];

    // Uniform call across the workgroup — EXT_mesh_shader requires
    // SetMeshOutputsEXT to be in dynamically uniform control flow.
    SetMeshOutputsEXT(8u, 12u);

    // Lane 0 averages the 8 world-space slab corners so every other
    // lane can push its own corner outward from this centroid.  Doing
    // this in lane 0 avoids relying on subgroup ops that may include
    // inactive lanes when the workgroup (8) is smaller than the warp
    // size (32 on NV).
    if (lane == 0u) {
        vec3 sum = vec3(0.0);
        for (uint i = 0u; i < 8u; ++i) {
            sum += lights_params.cascade_slab_corners_ws[
                cascade_idx * 8u + i].xyz;
        }
        s_centroid_ws = sum / 8.0;
    }
    barrier();

    // Each of the 8 lanes emits one hex corner, pushed outward from
    // the slab centroid by SILHOUETTE_MARGIN_WS world metres so the
    // projected silhouette grows by at least the PCF kernel radius in
    // every direction.  See the #define block above for the rationale.
    if (lane < 8u) {
        vec3 corner_ws = lights_params.cascade_slab_corners_ws[
            cascade_idx * 8u + lane].xyz;
        vec3 dir = corner_ws - s_centroid_ws;
        float len = length(dir);
        if (len > 1e-5) {
            corner_ws += (dir / len) * SILHOUETTE_MARGIN_WS;
        }
        vec4 clip = vp * vec4(corner_ws, 1.0);
        // Force NDC z = 1.0 (far in Vulkan [0,1] depth range) so the
        // entire silhouette interior gets the MAX possible depth, which
        // every real shadow caster (z < 1.0) can subsequently overwrite
        // via LESS_OR_EQUAL.
        clip.z = clip.w;
        gl_MeshVerticesEXT[lane].gl_Position = clip;
    }

    // Lanes 0..11 each emit one of the 12 hex triangles.  Workgroup
    // size is 8, so the loop covers the remaining triangles using
    // strided iteration.
    for (uint t = lane; t < 12u; t += gl_WorkGroupSize.x) {
        gl_PrimitiveTriangleIndicesEXT[t] = kHexTris[t];
        gl_MeshPrimitivesEXT[t].gl_Layer  = int(cascade_idx);
    }
}
