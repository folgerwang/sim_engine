# LibTorch is downloaded at setup time (~1 GB) and must not be committed.
# See ../../../.gitignore at the outer-repo level for the same entry; this
# copy exists because this directory is itself a git submodule and the
# outer .gitignore does not apply inside.
third_parties/libtorch/

# sherpa-onnx SDK (text-to-voice): ~100 MB of prebuilt DLLs/import libs,
# auto-downloaded by CMake at configure time (pinned version) — never commit.
# miniaudio (third_parties/miniaudio/) IS committed: single pinned header.
third_parties/sherpa-onnx/

# FUSE filesystem ghosts from open-but-unlinked files
.fuse_hidden*
**/.fuse_hidden*
